# Node.js dependencies
/node_modules

# Logs
*.log
logs/

# Runtime files
pids/
*.pid
*.seed

# Build output
/dist
/build

# Dependency directories
jspm_packages/

# OS or IDE generated files
.DS_Store        # macOS
Thumbs.db        # Windows
.vscode/          # VS Code settings folder
.idea/            # JetBrains IDEs (WebStorm, PhpStorm, etc.)

# Environment files
.env              # Environment variable files, don't commit sensitive info

